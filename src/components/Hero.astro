---
import { WHATSAPP, HERO } from '../lib/config';
const waUrl = WHATSAPP.message(WHATSAPP.messages.general);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-gradient-to-br from-vinotinto via-vinotinto-dark to-vinotinto"></div>
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, #FFD700 1px, transparent 1px), radial-gradient(circle at 80% 20%, #FFD700 1px, transparent 1px); background-size: 60px 60px, 80px 80px;"></div>
  <div class="absolute top-0 left-0 w-64 h-64 bg-oro/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-oro/5 rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-1.5 rounded-full mb-8">
      <span class="w-2 h-2 bg-oro rounded-full animate-pulse"></span>
      <span class="text-oro/90 text-sm font-medium tracking-wide">{HERO.badge}</span>
    </div>

    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold text-white leading-tight mb-6">
      {HERO.heading}
      <span class="text-oro block mt-2">{HERO.headingHighlight}</span>
    </h1>

    <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      {HERO.description}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-oro hover:bg-oro-light text-vinotinto-dark font-bold px-8 py-4 rounded-full text-lg transition-all shadow-2xl shadow-oro/30 hover:shadow-oro/50 hover:scale-105"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {HERO.cta}
      </a>
      <a
        href="#productos"
        class="inline-flex items-center gap-2 text-white/80 hover:text-white border border-white/20 hover:border-white/40 px-8 py-4 rounded-full text-lg transition-all"
      >
        {HERO.secondaryCta}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
    </div>
  </div>
</section>
