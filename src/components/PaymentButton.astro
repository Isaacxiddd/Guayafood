---
import { MERCADOPAGO } from '../lib/config';

interface Props {
  productName: string;
  productPrice: string;
  unitPrice: number;
  emoji?: string;
  description?: string;
}

const { productName, productPrice, unitPrice, emoji, description } = Astro.props;
---

<button
  class="mp-open-btn inline-flex items-center justify-center gap-2 bg-[#00BFFF] hover:bg-[#009ACD] text-white px-5 py-2.5 rounded-full text-sm font-semibold transition-all shadow-md hover:shadow-lg w-full"
  data-name={productName}
  data-price={productPrice}
  data-unit-price={unitPrice}
  data-emoji={emoji || ''}
  data-desc={description || ''}
>
  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm1-13h-2v6l5.25 3.15.75-1.23-4-2.37V7z"/></svg>
  {MERCADOPAGO.buttonText}
</button>

<script>
  document.querySelectorAll('.mp-open-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (typeof window.openOrderModal === 'function') {
        window.openOrderModal({
          name: btn.getAttribute('data-name'),
          price: btn.getAttribute('data-price'),
          unitPrice: Number(btn.getAttribute('data-unit-price')),
          emoji: btn.getAttribute('data-emoji'),
          description: btn.getAttribute('data-desc'),
        });
      }
    });
  });
</script>
